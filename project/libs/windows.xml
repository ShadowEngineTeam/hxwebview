<?xml version="1.0" encoding="UTF-8"?>
<xml>

    <set name="PROJECT_DIR" value="${haxelib:hxwebview}/project" />

    <target id="haxe">
        <section if="HXCPP_M64">
            <lib name="${PROJECT_DIR}/windows/x64/WebView2LoaderStatic.lib" />
        </section>

        <section if="HXCPP_M32">
            <lib name="${PROJECT_DIR}/windows/x86/WebView2LoaderStatic.lib" />
        </section>

        <section if="HXCPP_ARM64">
            <lib name="${PROJECT_DIR}/windows/arm64/WebView2LoaderStatic.lib" />
        </section>
    </target>

    <files id="haxe">
        <compilerflag value="-I${PROJECT_DIR}/windows" />
    </files>

    <files id="__main__">
        <compilerflag value="-I${PROJECT_DIR}/windows" />
    </files>
</xml>