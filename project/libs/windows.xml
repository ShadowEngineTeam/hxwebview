<xml>

    <set name="PROJECT_DIR" value="${haxelib:hxwebview}/project" />

    <files id="haxe">
        <compilerflag value="-I${PROJECT_DIR}/windows" />
    </files>

    <files id="__main__">
        <compilerflag value="-I${PROJECT_DIR}/windows" />
    </files>

    <target id="haxe">
        <section if="HXCPP_M64">
            <lib name="${PROJECT_DIR}/windows/x64/WebView2Loader.dll.lib" />
        </section>

        <section if="HXCPP_M32">
            <lib name="${PROJECT_DIR}/windows/x86/WebView2Loader.dll.lib" />
        </section>
    </target>

    <section if="HXCPP_M64">
        <copyFile name="WebView2Loader.dll" from="${PROJECT_DIR}/windows/x64" toolId="exe"
            overwrite="true" />
    </section>

    <section if="HXCPP_M32">
        <copyFile name="WebView2Loader.dll" from="${PROJECT_DIR}/windows/x86" toolId="exe"
            overwrite="true" />
    </section>

</xml>