<xml>

    <pragma once="true" />

	<set name="PROJECT_DIR" value="${haxelib:hxwebview}/project" />

    <section id="vars">
        <set name="NO_PRECOMPILED_HEADERS" value="1" if="linux" />
    </section>

    <section if="linux">
        <include name="${PROJECT_DIR}/vendor/linux.xml"/>
    </section>

    <section if="windows">
        <include name="${PROJECT_DIR}/vendor/windows.xml"/>
    </section>

    <files id="haxe">
        <compilerflag value="-I${PROJECT_DIR}/" />
    </files>

    <files id="__main__">
        <compilerflag value="-I${PROJECT_DIR}/" />
    </files>
</xml>
